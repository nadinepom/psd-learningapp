rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Jeder authentifizierte Nutzer (auch anonym) darf nur seinen eigenen
    // Lernstand lesen und schreiben. Kein Nutzer kann die Daten anderer sehen.
    match /progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
